// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // ใช้ SQLite สำหรับโปรแกรมทดลอง (เปลี่ยนเป็น postgresql ได้)
  url      = "file:./dev.db"
}

enum Role {
  USER
  ADMIN
}

enum SeatStatus {
  AVAILABLE
  SOLD
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String   // ควร Hash ก่อนบันทึก
  role     Role     @default(USER) // แยก Admin / User
  tickets  Ticket[] // ความสัมพันธ์ 1 User มีหลายตั๋ว
}

model Concert {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  date        String   // เช่น "Dec 12, 2024"
  time        String   // เช่น "8:00 PM"
  venue       String
  seats       Seat[]   // ความสัมพันธ์ 1 คอนเสิร์ต มีหลายที่นั่ง
}

model Seat {
  id        Int        @id @default(autoincrement())
  concertId Int
  concert   Concert    @relation(fields: [concertId], references: [id])
  row       String     // แถว เช่น "A", "B", "R"
  number    Int        // หมายเลขที่นั่ง เช่น 1, 2, 3
  tier      String     // ระดับที่นั่ง เช่น "VIP", "Regular" (โจทย์ข้อ 3.2)
  status    SeatStatus @default(AVAILABLE)
  ticket    Ticket?    // ถ้าขายแล้วจะมีตั๋วผูกอยู่
}

model Ticket {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  seatId      Int      @unique
  seat        Seat     @relation(fields: [seatId], references: [id])
  purchasedAt DateTime @default(now())
}