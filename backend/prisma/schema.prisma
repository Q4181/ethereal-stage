// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ลบ enum ออกทั้งหมด แล้วเปลี่ยน type ใน model เป็น String แทน

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String   
  role     String   @default("USER") // เปลี่ยนจาก Role เป็น String
  tickets  Ticket[] 
}

model Concert {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  date        String   
  time        String   
  venue       String
  seats       Seat[]   
}

model Seat {
  id        Int        @id @default(autoincrement())
  concertId Int
  concert   Concert    @relation(fields: [concertId], references: [id])
  row       String     
  number    Int        
  tier      String     
  status    String     @default("AVAILABLE") // เปลี่ยนจาก SeatStatus เป็น String
  ticket    Ticket?    
}

model Ticket {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  seatId      Int      @unique
  seat        Seat     @relation(fields: [seatId], references: [id])
  purchasedAt DateTime @default(now())
}